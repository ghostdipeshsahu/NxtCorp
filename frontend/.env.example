# Frontend env (Vite). Copy to `.env` for local dev (optional — defaults work).
# On Vercel, set these in the project's environment variables UI.

# Backend URL. Leave empty in dev (vite proxies /api -> localhost:8000).
# In prod, set to your deployed backend, e.g. https://nxtcorp-api.onrender.com
VITE_API_BASE=
