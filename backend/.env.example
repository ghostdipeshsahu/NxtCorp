# LLM provider — v6. Single chokepoint via OpenAI Python SDK; works against
# OpenAI direct, OpenRouter, or any OpenAI-compatible endpoint.
LLM_API_KEY=sk-or-v1-replace-me
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# Leave LLM_BASE_URL blank for direct OpenAI. Examples:
#   OpenAI direct:     LLM_BASE_URL=     (empty)              LLM_MODEL=gpt-4o-mini
#   OpenRouter:        LLM_BASE_URL=https://openrouter.ai/api/v1   LLM_MODEL=openai/gpt-4o-mini
#   OpenRouter Llama:  LLM_BASE_URL=https://openrouter.ai/api/v1   LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Legacy fallback (still read if LLM_* unset).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# Database — sqlite for local dev, Postgres in production.
# Render blueprint provides DATABASE_URL via fromDatabase automatically.
DATABASE_URL=sqlite:///./nxtcorp.db
# DATABASE_URL=postgresql+psycopg2://nxtcorp:nxtcorp@localhost:5432/nxtcorp

# Auth — generate a strong JWT_SECRET in prod with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS — comma-separated list of allowed frontend origins.
# In prod, add your Vercel URL (no trailing slash), e.g. https://nxtcorp.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App
SEED_QUESTION_ID=p001_bonus_calculator
